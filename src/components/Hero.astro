---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import heroPhoto from '../assets/photos/okolica/plaza-brzeg-morza.jpg';
---

<section class="hero" aria-labelledby="hero-title">
  <Image
    class="hero-photo"
    src={heroPhoto}
    alt=""
    width={2048}
    height={1152}
    fit="cover"
    widths={[640, 1024, 1600, 2048]}
    sizes="100vw"
    quality={72}
    format="webp"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="container hero-content">
    <p class="hero-eyebrow">Darłówko Zachodnie · pokoje gościnne</p>
    <h1 id="hero-title">Pokoje gościnne w&nbsp;Darłówku — 250&nbsp;m od&nbsp;plaży</h1>
    <p class="hero-lead">
      Morze u&nbsp;nas? Morze u&nbsp;nas! Rodzinne kwatery z&nbsp;łazienkami
      w&nbsp;cichej okolicy, kilka minut spacerem od&nbsp;szerokiej plaży,
      portu rybackiego i&nbsp;nadmorskiego deptaka.
    </p>
    <div class="hero-actions">
      <a class="btn btn--sun" href="/oferta.html">Zobacz ofertę</a>
      <a class="btn btn--ghost" href={site.phoneHref}>
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z"
          ></path>
        </svg>
        {site.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    align-items: end;
    min-height: min(88svh, 46rem);
    overflow: hidden;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 62%;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgb(10 46 61 / 0.82) 0%,
        rgb(10 46 61 / 0.45) 38%,
        rgb(10 46 61 / 0.08) 70%,
        rgb(10 46 61 / 0) 100%
      );
  }

  /* Na wąskich ekranach treść hero sięga wyżej — scrim musi kryć więcej zdjęcia */
  @media (max-width: 700px) {
    .hero-scrim {
      background:
        linear-gradient(
          to top,
          rgb(10 46 61 / 0.85) 0%,
          rgb(10 46 61 / 0.62) 45%,
          rgb(10 46 61 / 0.35) 75%,
          rgb(10 46 61 / 0.2) 100%
        );
    }
  }

  .hero-content {
    position: relative;
    padding-block: var(--space-16) var(--space-24);
    display: grid;
    gap: var(--space-4);
    max-width: var(--maxw-content);
  }

  .hero-eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 650;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sun-400);
    text-shadow: 0 1px 10px rgb(10 46 61 / 0.65);
  }

  .hero-lead,
  .hero h1 {
    text-shadow: 0 1px 12px rgb(10 46 61 / 0.35);
  }

  .hero h1 {
    font-size: var(--text-hero);
    font-weight: 800;
    color: var(--white);
    max-width: 15ch;
  }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--sand-50);
    max-width: 48ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  /* wejście hero — jedna orkiestrowana sekwencja */
  @media (prefers-reduced-motion: no-preference) {
    .hero-eyebrow,
    .hero h1,
    .hero-lead,
    .hero-actions {
      animation: hero-rise 640ms cubic-bezier(0.2, 0.7, 0.3, 1) both;
    }

    .hero h1 {
      animation-delay: 90ms;
    }

    .hero-lead {
      animation-delay: 180ms;
    }

    .hero-actions {
      animation-delay: 270ms;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
