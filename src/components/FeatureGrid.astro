---
// Wyposażenie pokoi i udogodnienia — ikony rysowane inline (24px, stroke).
const features = [
  {
    label: 'Łazienka w każdym pokoju',
    icon: 'M7 3v6m0 0c-2.2 0-4 1.8-4 4v2a4 4 0 0 0 4 4h10a4 4 0 0 0 4-4v-2c0-2.2-1.8-4-4-4H7Zm2 16v2m6-2v2M7 6h4',
  },
  {
    label: 'Telewizor',
    icon: 'M4 6h16a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm4 14h8',
  },
  {
    label: 'Lodówka',
    icon: 'M7 3h10a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Zm-1 7h12M9 6v2m0 5v3',
  },
  {
    label: 'Czajnik',
    icon: 'M8 8h8l1 8a3 3 0 0 1-3 3h-4a3 3 0 0 1-3-3l1-8Zm8 2 3-1v4l-2 1M9 8c0-2 1-4 3-4s3 2 3 4',
  },
  {
    label: 'Parawany plażowe',
    icon: 'M12 3a9 9 0 0 0-9 9h18a9 9 0 0 0-9-9Zm0 0v18m0-2 3 2',
  },
  {
    label: 'Kącik grillowy',
    icon: 'M5 10h14a7 7 0 0 1-14 0Zm7 7v4m-4-1 2-3m6 3-2-3M8 6c0-1 .5-1.5.5-2.5M12 6c0-1 .5-1.5.5-2.5M16 6c0-1 .5-1.5.5-2.5',
  },
  {
    label: 'Aneks kuchenny z wyposażeniem',
    icon: 'M4 12h16v8H4v-8Zm3 0V7a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v5M8 16h2m4 0h2',
  },
  {
    label: 'Cicha okolica i ogród',
    icon: 'M12 3c3 3 5 6 5 9a5 5 0 0 1-10 0c0-3 2-6 5-9Zm0 9v9m0-5 3-2m-3-1-3-2',
  },
] as const;
---

<ul class="feature-grid" role="list">
  {
    features.map((feature) => (
      <li class="feature">
        <span class="feature-icon" aria-hidden="true">
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d={feature.icon} />
          </svg>
        </span>
        <span class="feature-label">{feature.label}</span>
      </li>
    ))
  }
</ul>

<style>
  .feature-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--space-4);
  }

  .feature {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--white);
    border: 1px solid var(--sand-200);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .feature-icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-pill);
    background: var(--sea-100);
    color: var(--sea-700);
  }

  .feature-label {
    font-weight: 650;
    color: var(--ink);
  }
</style>
