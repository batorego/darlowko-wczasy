---
import { site, navLinks } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="footer-name">{site.name}</p>
      <p class="footer-tagline">{site.tagline}</p>
      <address>
        {site.address.street}<br />
        {site.address.zip} {site.address.locality}
      </address>
    </div>

    <div>
      <p class="footer-heading">Na skróty</p>
      <ul class="footer-links">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="footer-heading">Rezerwacje</p>
      <ul class="footer-links">
        <li>
          <a href={site.phoneHref}>tel. {site.phoneDisplay}</a>
        </li>
        <li>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </li>
        <li>
          <a href={site.mapUrl} rel="noopener">Zobacz na mapie</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {site.name} · Wszystkie prawa zastrzeżone</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--sea-900);
    color: var(--sand-100);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--white);
  }

  .footer-tagline {
    color: var(--dune-300);
    margin-bottom: var(--space-3);
  }

  address {
    font-style: normal;
    line-height: 1.6;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dune-300);
    margin-bottom: var(--space-3);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  .footer a {
    color: var(--sand-50);
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--sun-400);
    text-decoration: underline;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-top: 1px solid rgb(253 251 247 / 0.15);
    font-size: var(--text-sm);
    color: var(--sand-100);
  }
</style>
