---
import { site, navLinks } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="footer-name">{site.name}</p>
      <p class="footer-tagline">{site.tagline}</p>
      <address>
        {site.address.street}<br />
        {site.address.zip} {site.address.locality}
      </address>
    </div>

    <div>
      <p class="footer-heading">Na skróty</p>
      <ul class="footer-links">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="footer-heading">Rezerwacje</p>
      <ul class="footer-links footer-links--icons">
        <li>
          <a href={site.phoneHref}>
            <!-- Lucide: phone -->
            <svg
              aria-hidden="true"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            <span>tel. {site.phoneDisplay}</span>
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`}>
            <!-- Lucide: mail -->
            <svg
              aria-hidden="true"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <span>{site.email}</span>
          </a>
        </li>
        <li>
          <a href={site.mapUrl} rel="noopener">
            <!-- Lucide: map-pin -->
            <svg
              aria-hidden="true"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
              ></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Zobacz na mapie</span>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {site.name} · Wszystkie prawa zastrzeżone</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--sea-900);
    color: var(--sand-100);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--white);
  }

  .footer-tagline {
    color: var(--dune-300);
    margin-bottom: var(--space-3);
  }

  address {
    font-style: normal;
    line-height: 1.6;
  }

  .footer-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dune-300);
    margin-bottom: var(--space-3);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  .footer a {
    color: var(--sand-50);
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--sun-400);
    text-decoration: underline;
  }

  .footer-links--icons a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-links--icons svg {
    flex-shrink: 0;
    color: var(--dune-300);
    transition: color 160ms ease;
  }

  .footer-links--icons a:hover svg {
    color: var(--sun-400);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-top: 1px solid rgb(253 251 247 / 0.15);
    font-size: var(--text-sm);
    color: var(--sand-100);
  }
</style>
