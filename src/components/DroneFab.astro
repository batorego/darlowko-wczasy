---
// Pływająca, nienachalna zajawka filmów z drona (tylko strona Galerii).
// Pojawia się po przescrollowaniu pierwszego ekranu zdjęć,
// znika, gdy sekcja #z-drona jest widoczna.
---

<a class="drone-fab" href="#z-drona" aria-hidden="true" tabindex="-1">
  <span class="drone-fab__icon" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8 5.14v13.72c0 .8.87 1.3 1.56.88l10.5-6.86a1.03 1.03 0 0 0 0-1.76L9.56 4.26A1.03 1.03 0 0 0 8 5.14Z"></path>
    </svg>
  </span>
  Filmy z drona
</a>

<style>
  .drone-fab {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-6);
    z-index: 40;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.65em 1.2em;
    border-radius: var(--radius-pill);
    background: var(--sea-700);
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    text-decoration: none;
    box-shadow: var(--shadow-2);
    /* stan ukryty */
    visibility: hidden;
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease, visibility 0s linear 220ms;
  }

  .drone-fab--visible {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .drone-fab:hover {
    background: var(--sea-500);
    color: var(--white);
  }

  .drone-fab__icon {
    display: grid;
    place-items: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: var(--radius-pill);
    background: rgb(253 251 247 / 0.18);
  }
</style>

<script src="../scripts/drone-fab.ts"></script>
