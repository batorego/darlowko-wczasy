---
// Lekkie osadzenie YouTube: do kliknięcia tylko miniatura (fasada),
// potem iframe youtube-nocookie z autoplay. Bez JS link otwiera film na YouTube.
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;
---

<a
  class="video-embed"
  href={`https://www.youtube.com/watch?v=${videoId}`}
  rel="noopener"
  data-video-id={videoId}
  data-video-title={title}
>
  <img
    src={`https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`}
    alt=""
    width="1280"
    height="720"
    loading="lazy"
  />
  <span class="video-play" aria-hidden="true">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8 5.14v13.72c0 .8.87 1.3 1.56.88l10.5-6.86a1.03 1.03 0 0 0 0-1.76L9.56 4.26A1.03 1.03 0 0 0 8 5.14Z"></path>
    </svg>
  </span>
  <span class="video-label">
    <span class="visually-hidden">Odtwórz film: </span>{title}
  </span>
</a>

<style>
  .video-embed {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-1);
    background: var(--sea-900);
    transition: box-shadow 200ms ease, transform 200ms ease;
  }

  .video-embed:hover {
    box-shadow: var(--shadow-2);
    transform: translateY(-3px);
  }

  .video-embed img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 4.25rem;
    height: 4.25rem;
    border-radius: var(--radius-pill);
    background: rgb(10 46 61 / 0.75);
    color: var(--white);
    padding-left: 4px;
    transition: background-color 160ms ease;
  }

  .video-embed:hover .video-play {
    background: var(--sea-700);
  }

  .video-label {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: var(--space-8) var(--space-4) var(--space-3);
    background: linear-gradient(to top, rgb(10 46 61 / 0.8), rgb(10 46 61 / 0));
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 700;
  }

  .video-embed :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .video-embed:hover {
      transform: none;
    }
  }
</style>

<script src="../scripts/video-embed.ts"></script>
