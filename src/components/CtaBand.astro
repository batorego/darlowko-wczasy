---
import { site } from '../data/site';

interface Props {
  title?: string;
  note?: string;
}

const {
  title = 'Zaplanuj wakacje nad Bałtykiem',
  note = 'Rezerwacje przyjmujemy telefonicznie — chętnie odpowiemy na każde pytanie.',
} = Astro.props;
---

<section class="cta-band">
  <div class="container cta-inner">
    <div>
      <h2>{title}</h2>
      <p>{note}</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn--sun" href={site.phoneHref}>
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z"
          ></path>
        </svg>
        Zadzwoń: {site.phoneDisplay}
      </a>
      <a class="cta-secondary" href="/kontakt.html">Dane kontaktowe i dojazd</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: var(--sea-700);
    padding-block: var(--space-16);
  }

  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .cta-band h2 {
    color: var(--white);
  }

  .cta-band p {
    color: var(--sea-100);
    margin-top: var(--space-2);
    max-width: 44ch;
  }

  .cta-actions {
    display: grid;
    justify-items: start;
    gap: var(--space-3);
  }

  .cta-secondary {
    color: var(--sand-50);
    text-underline-offset: 4px;
  }

  .cta-secondary:hover {
    color: var(--sun-400);
  }
</style>
